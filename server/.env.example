# Supabase (use SERVICE ROLE key, not anon key — server needs full DB access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# YCloud
YCLOUD_API_KEY=your-ycloud-api-key
YCLOUD_WEBHOOK_SECRET=your-webhook-verification-token

# Encryption — AES-256-GCM key for API keys stored in the database.
# Must be exactly 64 hex characters (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=cb42e934b3120cf6e7c11bbcddcaf9cfd0983c599e9548f2a7a4bc11c90838a8

# Server
PORT=3000
