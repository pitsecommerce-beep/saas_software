# ============================================
# Supabase Configuration
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# Google OAuth (configured in Supabase Dashboard)
# ============================================
# These are NOT env vars for the app — they go in Supabase Dashboard:
#   Authentication > Providers > Google
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# YCloud Configuration (for WhatsApp/Instagram/Messenger)
# ============================================
VITE_YCLOUD_API_KEY=your-ycloud-api-key
VITE_YCLOUD_PHONE_NUMBER_ID=your-phone-number-id
VITE_YCLOUD_WEBHOOK_TOKEN=your-webhook-verification-token

# ============================================
# Backend API URL (Railway)
# ============================================
# URL of the Railway backend server for sending outbound messages
VITE_API_URL=https://your-service.up.railway.app

# ============================================
# Deployment — Base Path
# ============================================
# Set to '/' for Railway / root-path hosting.
# Set to '/saas_software/' for GitHub Pages sub-path hosting.
# If omitted, defaults to '/saas_software/'
VITE_BASE_PATH=/

# ============================================
# Railway Backend (for webhooks & edge functions)
# ============================================
# These go in Railway environment variables, NOT in the frontend:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# YCLOUD_API_KEY=your-ycloud-api-key
# YCLOUD_WEBHOOK_SECRET=your-ycloud-webhook-secret
# YCLOUD_PHONE_NUMBER_ID=your-phone-number-id
